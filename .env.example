# LLM — any OpenAI-compatible endpoint (vLLM, Ollama, llama.cpp, etc.)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=your-model-name
VLLM_API_KEY=dummy

# ===== Agent tuning (optional) =====
# Max autonomous steps before the agent stops itself
AGENT_MAX_STEPS=30
# true = headless; the browser is streamed into the dashboard (no separate window),
# and you take over right in the live preview. Set false to also pop a real window.
AGENT_HEADLESS=true
# Streamed viewport size (also the click-mapping reference)
AGENT_VIEWPORT_W=1280
AGENT_VIEWPORT_H=800
# Live-stream tuning — lower = lighter on CPU. quality 1-100, everyNth >=1 (skip frames)
AGENT_STREAM_QUALITY=45
AGENT_STREAM_EVERY_NTH=2
# Control-panel port
AGENT_PORT=8001

# ===== Short-term memory (per thread_id) =====
# Default = SQLite (zero-setup, backend/../memory.db). For Postgres, set a URL
# (and `pip install "psycopg[binary]"`):
# AGENT_DATABASE_URL=postgresql://user:pass@localhost:5432/browser_agent
# How many recent tasks-in-a-thread to feed back as context
AGENT_MEMORY_TURNS=10
# Browser channel: "chrome" uses real Google Chrome (its headless passes anti-bot
# checks that block Playwright's bundled headless shell, e.g. Tokopedia). Falls back
# to bundled Chromium if Chrome isn't installed. Empty = always bundled Chromium.
AGENT_BROWSER_CHANNEL=chrome
# Custom user agent (empty = auto: real UA with the "HeadlessChrome" token stripped)
# AGENT_USER_AGENT=
# Persistent Chrome profile dir (default: browser_agent/.profile)
# AGENT_USER_DATA_DIR=
