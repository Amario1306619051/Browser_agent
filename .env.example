# LLM — any OpenAI-compatible endpoint (vLLM, Ollama, llama.cpp, etc.)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=your-model-name
VLLM_API_KEY=dummy

# ===== Agent tuning (optional) =====
# Max autonomous steps before the agent stops itself
AGENT_MAX_STEPS=30
# false = browser is visible (KEEP false so you can take over manually)
AGENT_HEADLESS=false
# Control-panel port
AGENT_PORT=8001
# Custom user agent (empty = Playwright default Chromium UA)
# AGENT_USER_AGENT=
# Persistent Chrome profile dir (default: browser_agent/.profile)
# AGENT_USER_DATA_DIR=
